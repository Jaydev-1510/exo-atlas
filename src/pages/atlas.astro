---
import Layout from "@/layouts/base.astro";
import PlanetCard from "@/components/planetCard.astro";
import { supabase } from "@/lib/supabase";
// 
const searchParams = Astro.url.searchParams;
const q = searchParams.get("q") || "";
const type = searchParams.get("type") || "";
const sort = searchParams.get("sort") || "habitability_pct";
const hab = searchParams.get("habitable") === "true";

const { data: planets } = await supabase.rpc("get_planets", {
  p_search: q || undefined,
  p_type: type || undefined,
  p_method: undefined,
  p_habitable: hab || undefined,
  p_year_from: undefined,
  p_year_to: undefined,
  p_radius_min: undefined,
  p_radius_max: undefined,
  p_sort: sort,
  p_order: "desc",
  p_limit: 48,
  p_offset: 0,
});

const total = planets?.[0]?.total_count ?? 0;
const types = [
  { value: "", label: "All types" },
  { value: "rocky", label: "Rocky" },
  { value: "super-earth", label: "Super-earth" },
  { value: "sub-neptune", label: "Sub-neptune" },
  { value: "ocean-world", label: "Ocean world" },
  { value: "hot-jupiter", label: "Hot Jupiter" },
  { value: "gas-giant", label: "Gas giant" },
];

const sorts = [
  { value: "habitability_pct", label: "Habitability" },
  { value: "esi_score", label: "ESI score" },
  { value: "distance_ly", label: "Distance" },
  { value: "discovery_year", label: "Discovery" },
];
---

<Layout title="Atlas — Exoplanet Atlas">
  <header class="flex items-center justify-center py-10 min-h-[12em]">
    <h1
      class="absolute text-center font-bold font-pixel-line tracking-tighter text-[12em] select-none bg-linear-0 from-black to-primary text-transparent bg-clip-text whitespace-nowrap leading-40"
    >
      Planet Atlas.
    </h1>
    <params class="font-mono text-md text-secondary mt-[8em] z-20">
      Browse {Number(total).toLocaleString()} worlds
    </params>
  </header>

  <div class="flex flex-wrap gap-2 mb-6" id="filter-bar">
    <input
      id="search"
      type="text"
      value={q}
      placeholder="Search planets, stars..."
      class="bg-background-200 border border-gray-300 rounded-lg px-3 py-2 text-sm text-primary placeholder:text-gray-500 focus:outline-none focus:border-gray-600 w-56"
    />
    <div class="flex gap-1.5 flex-wrap">
      {
        types.map((t) => (
          <button
            data-filter="type"
            data-value={t.value}
            class={`filter-pill text-xs px-3 py-1.5 rounded-full border transition-colors cursor-pointer ${
              type === t.value
                ? "bg-primary text-background-100 border-primary"
                : "border-gray-300 text-gray-700 hover:border-gray-500"
            }`}
          >
            {t.label}
          </button>
        ))
      }
    </div>

    <div class="flex items-center gap-2 ml-auto">
      <label class="text-xs text-gray-600">Sort</label>
      <select
        id="sort-select"
        class="bg-background-200 border border-gray-300 rounded-lg px-2 py-1.5 text-xs text-secondary focus:outline-none"
      >
        {
          sorts.map((s) => (
            <option value={s.value} selected={sort === s.value}>
              {s.label}
            </option>
          ))
        }
      </select>

      <label
        class="flex items-center gap-1.5 text-xs text-gray-700 cursor-pointer"
      >
        <input
          type="checkbox"
          id="hab-toggle"
          checked={hab}
          class="accent-green-500"
        />
        Habitable zone
      </label>
    </div>
  </div>

  <div
    id="grid-outer"
    class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5"
  >
    <div id="planet-grid" class="contents">
      {planets?.map((params) => <PlanetCard {...params} />)}
    </div>
  </div>
  <div
    id="empty-state"
    class="hidden items-center justify-center py-30 border border-dashed border-white/10 rounded-lg"
  >
    <params class="text-sm text-center tracking-widest uppercase text-gray-500">
      No planets found.
    </params>
  </div>
  <div id="load-more-wrap" class="flex justify-center mt-10">
    <button
      id="load-more"
      data-offset="48"
      data-total={total}
      class="border border-gray-300 text-gray-700 text-sm px-6 py-2.5 rounded-lg hover:border-gray-500 transition-colors"
    >
      Load more
    </button>
  </div>
</Layout>

<script>
  const searchEl = document.getElementById("search") as HTMLInputElement;
  const sortSel = document.getElementById("sort-select") as HTMLSelectElement;
  const habToggle = document.getElementById("hab-toggle") as HTMLInputElement;
  const grid = document.getElementById("planet-grid")!;
  const loadMore = document.getElementById("load-more") as HTMLButtonElement;
  const loadWrap = document.getElementById("load-more-wrap")!;
  const gridOuter = document.getElementById("grid-outer")!;
  const noDataFound = document.getElementById("empty-state")!;

  interface Params {
    q: string;
    type: string;
    sort: string;
    habitable: boolean;
  }

  function readParams(): Params {
    const searchParams = new URLSearchParams(window.location.search);
    return {
      q: searchParams.get("q") || "",
      type: searchParams.get("type") || "",
      sort: searchParams.get("sort") || "habitability_pct",
      habitable: searchParams.get("habitable") === "true",
    };
  }

  function pushURL(params: Params) {
    const searchParams = new URLSearchParams();
    if (params.q) searchParams.set("q", params.q);
    if (params.type) searchParams.set("type", params.type);
    if (params.sort && params.sort !== "habitability_pct")
      searchParams.set("sort", params.sort);
    if (params.habitable) searchParams.set("habitable", "true");
    window.history.pushState({}, "", `?${searchParams.toString()}`);
  }

  async function fetchCards(params: Params, offset = 0, replace = true) {
    console.log("fetchCards", params);

    if (replace) {
      gridOuter.innerHTML =
        '<div style="grid-column:1/-1;padding:2rem;text-align:center;color:var(--ds-gray-600);font-size:.875rem">Loading...</div>';
    }

    const searchParams = new URLSearchParams();
    if (params.q) searchParams.set("q", params.q);
    if (params.type) searchParams.set("type", params.type);
    if (params.sort) searchParams.set("sort", params.sort);
    if (params.habitable) searchParams.set("habitable", "true");
    searchParams.set("limit", "48");
    searchParams.set("offset", String(offset));

    const res = await fetch(`/api/planets?${searchParams}`);
    const json = await res.json();

    if (replace) gridOuter.innerHTML = "";

    if (!json.data?.length) {
      noDataFound.classList.remove("hidden");
    } else {
      noDataFound.classList.add("hidden");
    }

    json.data.forEach((planet: any) => {
      const card = document.createElement("a");
      card.href = `/planet/${planet.name.toLowerCase().replace(/\s+/g, "-")}`;
      card.style.cssText =
        "display:block;background:var(--ds-background-200);border:1px solid var(--ds-gray-300);border-radius:.75rem;overflow:hidden;text-decoration:none;transition:border-color 150ms;cursor:pointer";
      card.onmouseenter = () => (card.style.borderColor = "var(--ds-gray-500)");
      card.onmouseleave = () => (card.style.borderColor = "var(--ds-gray-300)");
      card.innerHTML = buildCard(planet);
      gridOuter.appendChild(card);
    });

    drawPlanets();

    loadMore.dataset.offset = String(offset + 48);
    loadMore.dataset.total = String(json.meta.total);
    loadWrap.style.display = json.meta.hasMore ? "flex" : "none";
  }

  function buildCard(params: any) {
    const typeStyles: Record<string, string> = {
      rocky: "bg-amber-100 text-amber-500",
      "super-earth": "bg-teal-200 text-teal-800",
      "sub-neptune": "bg-blue-200 text-blue-800",
      "neptune-like": "bg-blue-200 text-blue-800",
      "ocean-world": "bg-blue-200 text-blue-800",
      "hot-jupiter": "bg-amber-200 text-amber-800",
      "gas-giant": "bg-purple-200 text-purple-800",
      unknown: "bg-gray-200 text-gray-700",
    };
    const typeLabels: Record<string, string> = {
      rocky: "Rocky",
      "super-earth": "Super-earth",
      "sub-neptune": "Sub-neptune",
      "neptune-like": "Neptune-like",
      "ocean-world": "Ocean world",
      "hot-jupiter": "Hot Jupiter",
      "gas-giant": "Gas giant",
      unknown: "Unknown",
    };

    const typeStyle = typeStyles[params.planet_type] ?? typeStyles["unknown"];
    const typeLabel = typeLabels[params.planet_type] ?? "Unknown";

    const habPct = params.habitability_pct ?? 0;
    const habColor =
      habPct >= 70
        ? "var(--ds-green-600)"
        : habPct >= 40
          ? "var(--ds-amber-600)"
          : "var(--ds-red-600)";

    const fmt = (v: any, d = 2) => (v != null ? Number(v).toFixed(d) : "—");
    const period =
      params.orbital_period == null
        ? "—"
        : params.orbital_period < 1
          ? `${(params.orbital_period * 24).toFixed(1)}h`
          : params.orbital_period > 1000
            ? `${(params.orbital_period / 365.25).toFixed(1)}yr`
            : `${Number(params.orbital_period).toFixed(1)}d`;

    return `
      <div style="height:7rem;background:var(--ds-background-100);display:flex;align-items:center;justify-content:center;border-bottom:1px solid var(--ds-gray-200)">
        <canvas class="planet-canvas" data-type="${params.planet_type}" data-radius="${params.radius_earth ?? 1}" width="80" height="80"></canvas>
      </div>
      <div style="padding:.75rem">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:.5rem;margin-bottom:.25rem">
          <div>
            <div style="font-size:.875rem;font-weight:500;color:var(--primary);line-height:1.25">${params.name}</div>
            <div style="font-size:.75rem;color:var(--ds-gray-600);font-family:var(--font-geist-mono);margin-top:.125rem">${params.host_star}</div>
          </div>
          <span class="${typeStyle}" style="flex-shrink:0;font-size:.625rem;font-weight:500;padding:.125rem .5rem;border-radius:999px;">${typeLabel}</span>
        </div>
        <div style="display:flex;align-items:center;gap:.5rem;margin-top:.75rem;margin-bottom:.25rem">
          <div style="flex:1;height:3px;background:var(--ds-gray-300);border-radius:2px;overflow:hidden">
            <div style="width:${habPct}%;height:100%;border-radius:2px;background:${habColor}"></div>
          </div>
          <span style="font-family:var(--font-geist-mono);font-size:.625rem;color:var(--ds-gray-600);min-width:2rem;text-align:right">${habPct}%</span>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:.375rem .75rem;margin-top:.75rem;padding-top:.75rem;border-top:1px solid var(--ds-gray-200)">
          <div>
            <div style="font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--ds-gray-500)">Radius</div>
            <div style="font-family:var(--font-geist-mono);font-size:.75rem;color:var(--secondary);margin-top:.125rem">${fmt(params.radius_earth)} R⊕</div>
          </div>
          <div>
            <div style="font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--ds-gray-500)">Period</div>
            <div style="font-family:var(--font-geist-mono);font-size:.75rem;color:var(--secondary);margin-top:.125rem">${period}</div>
          </div>
          <div>
            <div style="font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--ds-gray-500)">Temp</div>
            <div style="font-family:var(--font-geist-mono);font-size:.75rem;color:var(--secondary);margin-top:.125rem">${fmt(params.eq_temperature, 0)} K</div>
          </div>
          <div>
            <div style="font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--ds-gray-500)">Found</div>
            <div style="font-family:var(--font-geist-mono);font-size:.75rem;color:var(--secondary);margin-top:.125rem">${params.discovery_year ?? "—"}</div>
          </div>
        </div>
      </div>`;
  }

  function drawPlanets() {
    const COLORS: Record<string, string[]> = {
      rocky: ["#8a7040", "#6a5030"],
      "super-earth": ["#3a9e75", "#1a7e55"],
      "sub-neptune": ["#4a8ed4", "#2a6eb4"],
      "neptune-like": ["#3a7ed4", "#1a5eb4"],
      "ocean-world": ["#3a7ed4", "#1a5eb4"],
      "hot-jupiter": ["#E87C1E", "#c85c0e"],
      "gas-giant": ["#8a5bc4", "#6a3ba4"],
      unknown: ["#505050", "#303030"],
    };
    gridOuter
      .querySelectorAll<HTMLCanvasElement>(".planet-canvas")
      .forEach((canvas) => {
        if (canvas.dataset.drawn) return;
        canvas.dataset.drawn = "1";
        const type = canvas.dataset.type ?? "unknown";
        const radius = parseFloat(canvas.dataset.radius ?? "1");
        const context = canvas.getContext("2d");
        if (!context) return;
        const [color1, color2] = COLORS[type] ?? COLORS["unknown"];
        const size = canvas.width,
          centerX = size / 2,
          centerY = size / 2;
        const r = Math.min(Math.max(radius * 10, 8), size * 0.44);
        const gradient = context.createRadialGradient(
          centerX - r * 0.3,
          centerY - r * 0.3,
          r * 0.1,
          centerX,
          centerY,
          r,
        );
        gradient.addColorStop(0, color1);
        gradient.addColorStop(1, color2);
        context.beginPath();
        context.arc(centerX, centerY, r, 0, Math.PI * 2);
        context.fillStyle = gradient;
        context.fill();
        context.beginPath();
        context.arc(
          centerX - r * 0.25,
          centerY - r * 0.25,
          r * 0.35,
          0,
          Math.PI * 2,
        );
        context.fillStyle = "rgba(255,255,255,0.07)";
        context.fill();
      });
  }

  function syncFilterUI(params: Params) {
    searchEl.value = params.q;

    document.querySelectorAll(".filter-pill").forEach((btn) => {
      const value = (btn as HTMLElement).dataset.value ?? "";
      const active = value === params.type;
      btn.classList.toggle("bg-primary", active);
      btn.classList.toggle("text-background-100", active);
      btn.classList.toggle("border-primary", active);
      btn.classList.toggle("border-gray-300", !active);
      btn.classList.toggle("text-gray-700", !active);
    });

    sortSel.value = params.sort;
    habToggle.checked = params.habitable;
  }

  drawPlanets();

  let searchTimer: ReturnType<typeof setTimeout>;
  searchEl.addEventListener("input", () => {
    clearTimeout(searchTimer);
    noDataFound.classList.add("hidden");
    searchTimer = setTimeout(() => {
      const params = { ...readParams(), q: searchEl.value };
      pushURL(params);
      syncFilterUI(params);
      fetchCards(params, 0, true);
    }, 300);
  });

  document.querySelectorAll(".filter-pill").forEach((btn) => {
    btn.addEventListener("click", () => {
      const value = (btn as HTMLElement).dataset.value ?? "";
      const params = { ...readParams(), type: value };
      pushURL(params);
      syncFilterUI(params);
      fetchCards(params, 0, true);
    });
  });

  sortSel.addEventListener("change", () => {
    const params = { ...readParams(), sort: sortSel.value };
    pushURL(params);
    fetchCards(params, 0, true);
  });

  habToggle.addEventListener("change", () => {
    const params = { ...readParams(), habitable: habToggle.checked };
    pushURL(params);
    fetchCards(params, 0, true);
  });

  loadMore.addEventListener("click", () => {
    fetchCards(readParams(), Number(loadMore.dataset.offset), false);
  });
</script>
