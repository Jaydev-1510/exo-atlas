---
import Layout from "@/layouts/base.astro";
import PlanetCard from "@/components/planetCard.astro";
import { supabase } from "@/lib/supabase";

const sp = Astro.url.searchParams;
const q = sp.get("q") || "";
const type = sp.get("type") || "";
const sort = sp.get("sort") || "habitability_pct";
const hab = sp.get("habitable") === "true";

const { data: planets } = await supabase.rpc("get_planets", {
  p_search: q || undefined,
  p_type: type || undefined,
  p_method: undefined,
  p_habitable: hab || undefined,
  p_year_from: undefined,
  p_year_to: undefined,
  p_radius_min: undefined,
  p_radius_max: undefined,
  p_sort: sort,
  p_order: "desc",
  p_limit: 48,
  p_offset: 0,
});

const total = planets?.[0]?.total_count ?? 0;
const types = [
  { value: "", label: "All types" },
  { value: "rocky", label: "Rocky" },
  { value: "super-earth", label: "Super-earth" },
  { value: "sub-neptune", label: "Sub-neptune" },
  { value: "ocean-world", label: "Ocean world" },
  { value: "hot-jupiter", label: "Hot Jupiter" },
  { value: "gas-giant", label: "Gas giant" },
];

const sorts = [
  { value: "habitability_pct", label: "Habitability" },
  { value: "esi_score", label: "ESI score" },
  { value: "distance_ly", label: "Distance" },
  { value: "discovery_year", label: "Discovery" },
];
---

<Layout title="Atlas — Exoplanet Atlas">
  <header class="flex items-center justify-center py-10 min-h-[12em]">
    <h1
      class="absolute text-center font-bold font-pixel-line tracking-tighter text-[12em] select-none bg-linear-0 from-black to-primary text-transparent bg-clip-text whitespace-nowrap leading-40"
    >
      Planet Atlas
    </h1>
    <p class="font-mono text-md text-secondary mt-[8em] z-20">
      Browse {Number(total).toLocaleString()} worlds
    </p>
  </header>

  <div class="flex flex-wrap gap-2 mb-6" id="filter-bar">
    <input
      id="search"
      type="text"
      value={q}
      placeholder="Search planets, stars..."
      class="bg-background-200 border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-1000 placeholder:text-gray-500 focus:outline-none focus:border-gray-600 w-56"
    />
    <div class="flex gap-1.5 flex-wrap">
      {
        types.map((t) => (
          <button
            data-filter="type"
            data-value={t.value}
            class={`filter-pill text-xs px-3 py-1.5 rounded-full border transition-colors cursor-pointer ${
              type === t.value
                ? "bg-gray-1000 text-background-100 border-gray-1000"
                : "border-gray-300 text-gray-700 hover:border-gray-500"
            }`}
          >
            {t.label}
          </button>
        ))
      }
    </div>

    <div class="flex items-center gap-2 ml-auto">
      <label class="text-xs text-gray-600">Sort</label>
      <select
        id="sort-select"
        class="bg-background-200 border border-gray-300 rounded-lg px-2 py-1.5 text-xs text-gray-900 focus:outline-none"
      >
        {
          sorts.map((s) => (
            <option value={s.value} selected={sort === s.value}>
              {s.label}
            </option>
          ))
        }
      </select>

      <label
        class="flex items-center gap-1.5 text-xs text-gray-700 cursor-pointer"
      >
        <input
          type="checkbox"
          id="hab-toggle"
          checked={hab}
          class="accent-green-500"
        />
        Habitable zone
      </label>
    </div>
  </div>

  <div
    id="grid-outer"
    class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3"
  >
    <div id="planet-grid" class="contents">
      {planets?.map((p) => <PlanetCard {...p} />)}
    </div>
  </div>

  <div id="load-more-wrap" class="flex justify-center mt-10">
    <button
      id="load-more"
      data-offset="48"
      data-total={total}
      class="border border-gray-300 text-gray-700 text-sm px-6 py-2.5 rounded-lg hover:border-gray-500 transition-colors"
    >
      Load more
    </button>
  </div>
</Layout>

<script>
  const searchEl = document.getElementById("search") as HTMLInputElement;
  const sortSel = document.getElementById("sort-select") as HTMLSelectElement;
  const habToggle = document.getElementById("hab-toggle") as HTMLInputElement;
  const grid = document.getElementById("planet-grid")!;
  const loadMore = document.getElementById("load-more") as HTMLButtonElement;
  const loadWrap = document.getElementById("load-more-wrap")!;
  const gridOuter = document.getElementById("grid-outer")!;

  interface Params {
    q: string;
    type: string;
    sort: string;
    habitable: boolean;
  }

  function readParams(): Params {
    const sp = new URLSearchParams(window.location.search);
    return {
      q: sp.get("q") || "",
      type: sp.get("type") || "",
      sort: sp.get("sort") || "habitability_pct",
      habitable: sp.get("habitable") === "true",
    };
  }

  function pushURL(p: Params) {
    const sp = new URLSearchParams();
    if (p.q) sp.set("q", p.q);
    if (p.type) sp.set("type", p.type);
    if (p.sort && p.sort !== "habitability_pct") sp.set("sort", p.sort);
    if (p.habitable) sp.set("habitable", "true");
    window.history.pushState({}, "", `?${sp.toString()}`);
  }

  async function fetchCards(p: Params, offset = 0, replace = true) {
    console.log("fetchCards", p);

    if (replace) {
      gridOuter.innerHTML =
        '<div style="grid-column:1/-1;padding:2rem;text-align:center;color:var(--ds-gray-600);font-size:.875rem">Loading...</div>';
    }

    const sp = new URLSearchParams();
    if (p.q) sp.set("q", p.q);
    if (p.type) sp.set("type", p.type);
    if (p.sort) sp.set("sort", p.sort);
    if (p.habitable) sp.set("habitable", "true");
    sp.set("limit", "48");
    sp.set("offset", String(offset));

    const res = await fetch(`/api/planets?${sp}`);
    const json = await res.json();

    if (replace) gridOuter.innerHTML = "";

    if (!json.data?.length) {
      gridOuter.innerHTML =
        '<div style="grid-column:1/-1;padding:3rem;text-align:center;color:var(--ds-gray-600);font-size:.875rem">No planets found</div>';
      loadWrap.style.display = "none";
      return;
    }

    json.data.forEach((planet: any) => {
      const card = document.createElement("a");
      card.href = `/planet/${planet.name.toLowerCase().replace(/\s+/g, "-")}`;
      card.style.cssText =
        "display:block;background:var(--ds-background-200);border:1px solid var(--ds-gray-300);border-radius:.75rem;overflow:hidden;text-decoration:none;transition:border-color 150ms;cursor:pointer";
      card.onmouseenter = () => (card.style.borderColor = "var(--ds-gray-500)");
      card.onmouseleave = () => (card.style.borderColor = "var(--ds-gray-300)");
      card.innerHTML = buildCard(planet);
      gridOuter.appendChild(card);
    });

    drawPlanets();

    loadMore.dataset.offset = String(offset + 48);
    loadMore.dataset.total = String(json.meta.total);
    loadWrap.style.display = json.meta.hasMore ? "flex" : "none";
  }

  function buildCard(p: any) {
    const typeStyles: Record<string, string> = {
      rocky: "background:var(--ds-gray-200);color:var(--ds-gray-800)",
      "super-earth": "background:var(--ds-teal-200);color:var(--ds-teal-800)",
      "sub-neptune": "background:var(--ds-blue-200);color:var(--ds-blue-800)",
      "neptune-like": "background:var(--ds-blue-200);color:var(--ds-blue-800)",
      "ocean-world": "background:var(--ds-blue-200);color:var(--ds-blue-800)",
      "hot-jupiter": "background:var(--ds-amber-200);color:var(--ds-amber-800)",
      "gas-giant": "background:var(--ds-purple-200);color:var(--ds-purple-800)",
      unknown: "background:var(--ds-gray-200);color:var(--ds-gray-700)",
    };
    const typeLabels: Record<string, string> = {
      rocky: "Rocky",
      "super-earth": "Super-earth",
      "sub-neptune": "Sub-neptune",
      "neptune-like": "Neptune-like",
      "ocean-world": "Ocean world",
      "hot-jupiter": "Hot Jupiter",
      "gas-giant": "Gas giant",
      unknown: "Unknown",
    };

    const typeStyle = typeStyles[p.planet_type] ?? typeStyles["unknown"];
    const typeLabel = typeLabels[p.planet_type] ?? "Unknown";

    const habPct = p.habitability_pct ?? 0;
    const habColor =
      habPct >= 70
        ? "var(--ds-green-500)"
        : habPct >= 40
          ? "var(--ds-amber-500)"
          : "var(--ds-red-500)";

    const fmt = (v: any, d = 2) => (v != null ? Number(v).toFixed(d) : "—");
    const period =
      p.orbital_period == null
        ? "—"
        : p.orbital_period < 1
          ? `${(p.orbital_period * 24).toFixed(1)}h`
          : p.orbital_period > 1000
            ? `${(p.orbital_period / 365.25).toFixed(1)}yr`
            : `${Number(p.orbital_period).toFixed(1)}d`;

    return `
      <div style="height:7rem;background:var(--ds-background-100);display:flex;align-items:center;justify-content:center;border-bottom:1px solid var(--ds-gray-200)">
        <canvas class="planet-canvas" data-type="${p.planet_type}" data-radius="${p.radius_earth ?? 1}" width="80" height="80"></canvas>
      </div>
      <div style="padding:.75rem">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:.5rem;margin-bottom:.25rem">
          <div>
            <div style="font-size:.875rem;font-weight:500;color:var(--ds-gray-1000);line-height:1.25">${p.name}</div>
            <div style="font-size:.75rem;color:var(--ds-gray-600);font-family:var(--font-geist-mono);margin-top:.125rem">${p.host_star}</div>
          </div>
          <span style="flex-shrink:0;font-size:.625rem;font-weight:500;padding:.125rem .5rem;border-radius:999px;${typeStyle}">${typeLabel}</span>
        </div>
        <div style="display:flex;align-items:center;gap:.5rem;margin-top:.75rem;margin-bottom:.25rem">
          <div style="flex:1;height:3px;background:var(--ds-gray-300);border-radius:2px;overflow:hidden">
            <div style="width:${habPct}%;height:100%;border-radius:2px;background:${habColor}"></div>
          </div>
          <span style="font-family:var(--font-geist-mono);font-size:.625rem;color:var(--ds-gray-600);min-width:2rem;text-align:right">${habPct}%</span>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:.375rem .75rem;margin-top:.75rem;padding-top:.75rem;border-top:1px solid var(--ds-gray-200)">
          <div>
            <div style="font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--ds-gray-500)">Radius</div>
            <div style="font-family:var(--font-geist-mono);font-size:.75rem;color:var(--ds-gray-900);margin-top:.125rem">${fmt(p.radius_earth)} R⊕</div>
          </div>
          <div>
            <div style="font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--ds-gray-500)">Period</div>
            <div style="font-family:var(--font-geist-mono);font-size:.75rem;color:var(--ds-gray-900);margin-top:.125rem">${period}</div>
          </div>
          <div>
            <div style="font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--ds-gray-500)">Temp</div>
            <div style="font-family:var(--font-geist-mono);font-size:.75rem;color:var(--ds-gray-900);margin-top:.125rem">${fmt(p.eq_temperature, 0)} K</div>
          </div>
          <div>
            <div style="font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--ds-gray-500)">Found</div>
            <div style="font-family:var(--font-geist-mono);font-size:.75rem;color:var(--ds-gray-900);margin-top:.125rem">${p.discovery_year ?? "—"}</div>
          </div>
        </div>
      </div>`;
  }

  function drawPlanets() {
    const COLORS: Record<string, string[]> = {
      rocky: ["#8a7040", "#6a5030"],
      "super-earth": ["#3a9e75", "#1a7e55"],
      "sub-neptune": ["#4a8ed4", "#2a6eb4"],
      "neptune-like": ["#3a7ed4", "#1a5eb4"],
      "ocean-world": ["#3a7ed4", "#1a5eb4"],
      "hot-jupiter": ["#E87C1E", "#c85c0e"],
      "gas-giant": ["#8a5bc4", "#6a3ba4"],
      unknown: ["#505050", "#303030"],
    };
    gridOuter
      .querySelectorAll<HTMLCanvasElement>(".planet-canvas")
      .forEach((canvas) => {
        if (canvas.dataset.drawn) return;
        canvas.dataset.drawn = "1";
        const type = canvas.dataset.type ?? "unknown";
        const radius = parseFloat(canvas.dataset.radius ?? "1");
        const ctx = canvas.getContext("2d");
        if (!ctx) return;
        const [c1, c2] = COLORS[type] ?? COLORS["unknown"];
        const s = canvas.width,
          cx = s / 2,
          cy = s / 2;
        const r = Math.min(Math.max(radius * 10, 8), s * 0.44);
        const g = ctx.createRadialGradient(
          cx - r * 0.3,
          cy - r * 0.3,
          r * 0.1,
          cx,
          cy,
          r,
        );
        g.addColorStop(0, c1);
        g.addColorStop(1, c2);
        ctx.beginPath();
        ctx.arc(cx, cy, r, 0, Math.PI * 2);
        ctx.fillStyle = g;
        ctx.fill();
        ctx.beginPath();
        ctx.arc(cx - r * 0.25, cy - r * 0.25, r * 0.35, 0, Math.PI * 2);
        ctx.fillStyle = "rgba(255,255,255,0.07)";
        ctx.fill();
      });
  }

  function syncFilterUI(p: Params) {
    searchEl.value = p.q;

    document.querySelectorAll(".filter-pill").forEach((btn) => {
      const val = (btn as HTMLElement).dataset.value ?? "";
      const active = val === p.type;
      btn.classList.toggle("bg-gray-1000", active);
      btn.classList.toggle("text-background-100", active);
      btn.classList.toggle("border-gray-1000", active);
      btn.classList.toggle("border-gray-300", !active);
      btn.classList.toggle("text-gray-700", !active);
    });

    sortSel.value = p.sort;
    habToggle.checked = p.habitable;
  }

  drawPlanets();

  let searchTimer: ReturnType<typeof setTimeout>;
  searchEl.addEventListener("input", () => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => {
      const p = { ...readParams(), q: searchEl.value };
      pushURL(p);
      syncFilterUI(p);
      fetchCards(p, 0, true);
    }, 300);
  });

  document.querySelectorAll(".filter-pill").forEach((btn) => {
    btn.addEventListener("click", () => {
      const value = (btn as HTMLElement).dataset.value ?? "";
      const p = { ...readParams(), type: value };
      pushURL(p);
      syncFilterUI(p);
      fetchCards(p, 0, true);
    });
  });

  sortSel.addEventListener("change", () => {
    const p = { ...readParams(), sort: sortSel.value };
    pushURL(p);
    fetchCards(p, 0, true);
  });

  habToggle.addEventListener("change", () => {
    const p = { ...readParams(), habitable: habToggle.checked };
    pushURL(p);
    fetchCards(p, 0, true);
  });

  loadMore.addEventListener("click", () => {
    fetchCards(readParams(), Number(loadMore.dataset.offset), false);
  });
</script>
