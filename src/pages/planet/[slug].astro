---
import Layout from "@/layouts/base.astro";
import Icon from "@/components/icons.astro";
import SkyMap from "@/components/skyMap.astro";
import { supabase } from "@/lib/supabase";

export const prerender = false;

const { slug } = Astro.params;
const { data: planet } = await supabase
  .rpc("get_planet_by_slug", { p_name: slug ?? "" })
  .single();

if (!planet) return Astro.redirect("/atlas");

const fmt = (v: number | null, d = 2) =>
  v != null ? Number(v).toFixed(d) : "—";

const period =
  planet.orbital_period == null
    ? "—"
    : planet.orbital_period < 1
      ? `${(planet.orbital_period * 24).toFixed(1)}h`
      : planet.orbital_period > 1000
        ? `${(planet.orbital_period / 365.25).toFixed(1)} yr`
        : `${planet.orbital_period.toFixed(1)} days`;

const typeLabels: Record<string, string> = {
  rocky: "Rocky",
  "super-earth": "Super-earth",
  "sub-neptune": "Sub-neptune",
  "neptune-like": "Neptune-like",
  "ocean-world": "Ocean world",
  "hot-jupiter": "Hot Jupiter",
  "gas-giant": "Gas giant",
  unknown: "Unknown",
};

const typeStyles: Record<string, string> = {
  rocky: "bg-amber-100 text-amber-500",
  "super-earth": "bg-teal-200 text-teal-800",
  "sub-neptune": "bg-blue-200 text-blue-800",
  "neptune-like": "bg-blue-200 text-blue-800",
  "ocean-world": "bg-blue-200 text-blue-800",
  "hot-jupiter": "bg-amber-200 text-amber-800",
  "gas-giant": "bg-purple-200 text-purple-800",
  unknown: "bg-gray-200 text-gray-700",
};

const habColor =
  (planet.habitability_pct ?? 0) >= 70
    ? "var(--ds-green-500)"
    : (planet.habitability_pct ?? 0) >= 40
      ? "var(--ds-amber-500)"
      : "var(--ds-red-500)";

const planetType = planet.planet_type ?? "unknown";

const { data: similarPlanets } = await supabase.rpc("get_similar_planets", {
  p_planet_id: planet.id,
  p_limit: 4,
});
---

<Layout title={`${planet.name} — Exoplanet Atlas`}>
  <section class="max-w-4xl mx-auto px-4 py-10">
    <div class="mb-8 flex items-baseline justify-between">
      <div>
        <a
          href="/atlas"
          class="text-md text-gray-600 hover:text-secondary transition-colors flex gap-1 items-center group"
          ><Icon
            glyph="arrow-left"
            class="group-hover:-translate-x-2 group-hover:scale-110 transition-all duration-300"
          />Atlas</a
        >
      </div>
      <div class="flex items-center gap-3 mt-4">
        <button
          id="bookmark-btn"
          data-planet={JSON.stringify({
            id: planet.id,
            name: planet.name,
            host_star: planet.host_star,
            planet_type: planet.planet_type,
            habitability_pct: planet.habitability_pct,
            radius_earth: planet.radius_earth,
            discovery_year: planet.discovery_year,
          })}
          class="flex items-center gap-2 text-xs border border-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:border-gray-500 transition-colors"
        >
          <Icon id="bookmark-icon" glyph="bookmark" />
          <span id="bookmark-label">Save planet</span>
        </button>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
      <div
        class="bg-background-200 border border-gray-300 rounded-xl flex items-center justify-center h-full"
      >
        <canvas
          id="planet-canvas"
          width="200"
          height="200"
          data-type={planetType}
          data-radius={planet.radius_earth ?? 1}></canvas>
      </div>

      <div class="flex flex-col justify-center">
        <div class="flex items-center justify-between gap-3 mb-2">
          <h1 class="font-medium text-primary text-heading-48">
            {planet.name}
          </h1>
          <span
            class={`text-xs font-medium rounded-full py-1 px-2.5 ${typeStyles[planetType]}`}
          >
            {typeLabels[planetType]}
          </span>
        </div>
        <p class="font-mono text-sm text-gray-600 mb-6">
          {planet.host_star}
          {
            planet.distance_ly && (
              <span> · {fmt(planet.distance_ly, 1)} ly</span>
            )
          }
          {planet.stellar_type && <span> · {planet.stellar_type}</span>}
        </p>

        <div class="flex items-center gap-3 mb-6">
          <span class="text-xs text-gray-600">Habitability</span>
          <div class="flex-1 h-1.5 bg-gray-300 rounded-full overflow-hidden">
            <div
              class="h-full rounded-full"
              style={`width:${planet.habitability_pct ?? 0}%;background:${habColor}`}
            >
            </div>
          </div>
          <span class="font-mono text-sm text-secondary"
            >{planet.habitability_pct ?? 0}%</span
          >
        </div>

        <div class="grid grid-cols-2 gap-3">
          {
            [
              { label: "Radius", value: `${fmt(planet.radius_earth)} R⊕` },
              { label: "Mass", value: `${fmt(planet.mass_earth)} M⊕` },
              { label: "Period", value: period },
              {
                label: "Temperature",
                value: `${fmt(planet.eq_temperature, 0)} K`,
              },
              { label: "ESI score", value: fmt(planet.esi_score, 3) },
              {
                label: "Discovered",
                value: planet.discovery_year?.toString() ?? "—",
              },
            ].map((m) => (
              <div class="bg-background-100 border border-gray-200 rounded-lg px-3 py-2.5">
                <div class="text-[10px] text-gray-500 mb-1 uppercase tracking-[0.07em]">
                  {m.label}
                </div>
                <div class="font-mono text-sm text-primary">{m.value}</div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div class="bg-background-200 border border-gray-300 rounded-xl p-5">
        <div
          class="font-mono text-xs text-gray-600 uppercase tracking-widest mb-4"
        >
          Transit light curve
        </div>
        <canvas
          id="transit-canvas"
          width="100%"
          height="90"
          style="width:100%;height:90px"></canvas>
      </div>

      <div class="bg-background-200 border border-gray-300 rounded-xl p-5">
        <div
          class="font-mono text-xs text-gray-600 uppercase tracking-widest mb-4"
        >
          Size comparison
        </div>
        <div id="size-compare" class="flex items-end justify-center gap-6 py-2">
        </div>
      </div>
    </div>

    <SkyMap ra={planet.ra} dec={planet.dec} name={planet.name} />

    <div class="bg-background-200 border border-gray-300 rounded-xl p-5 mb-6">
      <div
        class="font-mono text-xs text-gray-600 uppercase tracking-widest mb-4"
      >
        Could I live here?
      </div>
      <div class="flex items-center gap-4 mb-4">
        <label class="text-sm text-gray-700 min-w-24">Your weight</label>
        <input
          type="range"
          id="weight-slider"
          min="30"
          max="200"
          value="70"
          step="1"
          class="flex-1 accent-green-500"
        />
        <span
          id="weight-out"
          class="font-mono text-sm text-secondary w-16 text-right">70 kg</span
        >
      </div>
      <div class="grid grid-cols-3 gap-3">
        <div class="bg-background-100 border border-gray-200 rounded-lg p-3">
          <div
            class="text-[10px] text-gray-500 mb-1 uppercase tracking-[0.07em]"
          >
            Weight here
          </div>
          <div id="res-weight" class="font-mono text-sm text-primary">— kg</div>
        </div>
        <div class="bg-background-100 border border-gray-200 rounded-lg p-3">
          <div
            class="text-[10px] text-gray-500 mb-1 uppercase tracking-[0.07em]"
          >
            Year length
          </div>
          <div class="font-mono text-sm text-primary">{period}</div>
        </div>
        <div class="bg-background-100 border border-gray-200 rounded-lg p-3">
          <div
            class="text-[10px] text-gray-500 mb-1 uppercase tracking-[0.07em]"
          >
            Surface gravity
          </div>
          <div id="res-gravity" class="font-mono text-sm text-primary">— g</div>
        </div>
      </div>
    </div>

    <div class="bg-background-200 border border-gray-300 rounded-xl p-5 mb-6">
      <div
        class="font-mono text-xs text-gray-600 uppercase tracking-widest mb-4"
      >
        Orbital period
      </div>
      <div class="flex md:flex-row flex-col items-center justify-between gap-5">
        <div
          class="flex md:flex-col flex-row justify-between md:gap-4 h-full min-w-64"
        >
          <div
            class="bg-background-100 border border-gray-200 rounded-lg px-4 py-3 h-16"
          >
            <div
              class="text-[10px] text-gray-500 mb-1 uppercase tracking-[0.07em]"
            >
              1 orbit takes
            </div>
            <div id="orbit-period-label" class="font-mono text-sm text-primary">
              {period}
            </div>
          </div>
          <div
            class="bg-background-100 border border-gray-200 rounded-lg px-4 py-3 h-16"
          >
            <div
              class="text-[10px] text-gray-500 mb-1 uppercase tracking-[0.07em]"
            >
              Speed vs Earth
            </div>
            <div id="orbit-speed-label" class="font-mono text-sm text-primary">
              —
            </div>
          </div>
          <div
            class="bg-background-100 border border-gray-200 rounded-lg px-4 py-3 h-16"
          >
            <div
              class="text-[10px] text-gray-500 mb-1 uppercase tracking-[0.07em]"
            >
              Your age there
            </div>
            <div id="orbit-age-label" class="font-mono text-sm text-primary">
              —
            </div>
          </div>
        </div>
        <div class="w-full flex items-center justify-center">
          <canvas id="orbit-canvas" width="260" height="224"></canvas>
        </div>
      </div>
    </div>
    <div class="bg-background-200 border border-gray-300 rounded-xl p-5 mb-6">
      <div
        class="font-mono text-xs text-gray-600 uppercase tracking-widest mb-4"
      >
        Host star
      </div>
      <div class="flex items-center justify-between">
        <div class="w-full flex items-center justify-center">
          <canvas id="star-canvas" width="120" height="120"></canvas>
        </div>
        <div class="grid grid-cols-2 gap-3 flex-1 min-w-135">
          <div
            class="bg-background-100 border border-gray-200 rounded-lg px-3 py-2.5"
          >
            <div
              class="text-[10px] text-gray-500 mb-1 uppercase tracking-[0.07em]"
            >
              Spectral type
            </div>
            <div class="font-mono text-sm text-primary">
              {planet.stellar_type ?? "—"}
            </div>
          </div>
          <div
            class="bg-background-100 border border-gray-200 rounded-lg px-3 py-2.5"
          >
            <div
              class="text-[10px] text-gray-500 mb-1 uppercase tracking-[0.07em]"
            >
              Temperature
            </div>
            <div class="font-mono text-sm text-primary">
              {
                planet.stellar_temp
                  ? `${Math.round(planet.stellar_temp).toLocaleString()} K`
                  : "—"
              }
            </div>
          </div>
          <div
            class="bg-background-100 border border-gray-200 rounded-lg px-3 py-2.5"
          >
            <div
              class="text-[10px] text-gray-500 mb-1 uppercase tracking-[0.07em]"
            >
              Star radius
            </div>
            <div class="font-mono text-sm text-primary">
              {
                planet.stellar_radius
                  ? `${Number(planet.stellar_radius).toFixed(2)} R☉`
                  : "—"
              }
            </div>
          </div>
          <div
            class="bg-background-100 border border-gray-200 rounded-lg px-3 py-2.5"
          >
            <div
              class="text-[10px] text-gray-500 mb-1 uppercase tracking-[0.07em]"
            >
              Star name
            </div>
            <div class="font-mono text-sm text-primary">
              {planet.host_star}
            </div>
          </div>
        </div>
      </div>
    </div>
    {
      similarPlanets && similarPlanets.length > 0 && (
        <div class="mt-8">
          <div class="font-mono text-xs text-gray-600 uppercase tracking-widest mb-4">
            Planets like this
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            {similarPlanets.map((planet) => {
              const slug = planet.name.toLowerCase().replace(/\s+/g, "-");
              const habColor =
                (planet.habitability_pct ?? 0) >= 70
                  ? "var(--ds-green-600)"
                  : (planet.habitability_pct ?? 0) >= 40
                    ? "var(--ds-amber-600)"
                    : "var(--ds-red-600)";
              return (
                <a
                  href={`/planet/${slug}`}
                  class="bg-background-200 border border-gray-300 rounded-xl p-3 hover:border-gray-500 transition-colors block"
                >
                  <div class="text-xs font-medium text-gray-1000 mb-1 truncate">
                    {planet.name}
                  </div>
                  <div class="font-mono text-xs text-gray-600 mb-2 truncate">
                    {planet.host_star}
                  </div>
                  <div class="flex items-center gap-1.5">
                    <div class="flex-1 h-1 bg-gray-300 rounded-full overflow-hidden">
                      <div
                        class="h-full rounded-full"
                        style={`width:${planet.habitability_pct ?? 0}%;background:${habColor}`}
                      />
                    </div>
                    <span class="font-mono text-xs text-gray-600">
                      {planet.habitability_pct ?? 0}%
                    </span>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      )
    }
  </section>
</Layout>

<script
  is:inline
  define:vars={{
    planetType,
    planetRadius: planet.radius_earth ?? 1,
    planetMass: planet.mass_earth ?? null,
    planetName: planet.name,
    planetPeriod: planet.orbital_period ?? 365,
    planetTemp: planet.eq_temperature ?? 255,
    stellarType: planet.stellar_type ?? null,
    stellarTemp: planet.stellar_temp ?? null,
    stellarRadius: planet.stellar_radius ?? 1,
  }}
>
  const COLORS = {
    rocky: ["#8a7040", "#6a5030"],
    "super-earth": ["#3a9e75", "#1a7e55"],
    "sub-neptune": ["#4a8ed4", "#2a6eb4"],
    "neptune-like": ["#3a7ed4", "#1a5eb4"],
    "ocean-world": ["#3a7ed4", "#1a5eb4"],
    "hot-jupiter": ["#E87C1E", "#c85c0e"],
    "gas-giant": ["#8a5bc4", "#6a3ba4"],
    unknown: ["#505050", "#303030"],
  };

  const planetCanvas = document.getElementById("planet-canvas");
  const planetContext = planetCanvas.getContext("2d");
  const [color1, color2] = COLORS[planetType] ?? COLORS["unknown"];
  const size = 200,
    centerX = size / 2,
    centerY = size / 2;
  const radius = Math.min(Math.max(planetRadius * 22, 12), size * 0.44);
  const gradient = planetContext.createRadialGradient(
    centerX - radius * 0.3,
    centerY - radius * 0.3,
    radius * 0.1,
    centerX,
    centerY,
    radius,
  );
  gradient.addColorStop(0, color1);
  gradient.addColorStop(1, color2);
  planetContext.beginPath();
  planetContext.arc(centerX, centerY, radius, 0, Math.PI * 2);
  planetContext.fillStyle = gradient;
  planetContext.fill();
  planetContext.beginPath();
  planetContext.arc(
    centerX - radius * 0.25,
    centerY - radius * 0.25,
    radius * 0.35,
    0,
    Math.PI * 2,
  );
  planetContext.fillStyle = "rgba(255,255,255,0.08)";
  planetContext.fill();

  const transitCanvas = document.getElementById("transit-canvas");
  transitCanvas.width = transitCanvas.offsetWidth || 400;
  const transitContext = transitCanvas.getContext("2d");
  const transitCanvasW = transitCanvas.width,
    transitCanvasH = 90;
  const MAX_TRANSIT_DIP = 30;
  const TRANSIT_SCALE_FACTOR = 3;
  const dip = Math.min(planetRadius * TRANSIT_SCALE_FACTOR, MAX_TRANSIT_DIP);

  transitContext.strokeStyle = "var(--ds-teal-500)";
  transitContext.lineWidth = 1.5;
  transitContext.beginPath();
  const transitPoints = [];
  for (let x = 0; x <= transitCanvasW; x++) {
    const t = x / transitCanvasW;
    const center = 0.5;
    const width = 0.12;
    let y = 20;
    if (Math.abs(t - center) < width) {
      const d = (t - center) / width;
      y += (dip * (1 - Math.cos(d * Math.PI))) / 2;
    }
    transitPoints.push([x, y]);
    x === 0 ? transitContext.moveTo(x, y) : transitContext.lineTo(x, y);
  }
  transitContext.stroke();

  transitContext.fillStyle = "var(--ds-gray-600)";
  transitContext.font = "10px monospace";
  transitContext.fillText("flux", 8, 16);
  transitContext.fillText("time →", transitCanvasW - 52, transitCanvasH - 6);
  transitContext.fillStyle = "var(--ds-teal-600)";
  transitContext.fillText(
    `−${((planetRadius ** 2 / 100) * 100).toFixed(2)}%`,
    transitCanvasW - 52,
    36,
  );

  let frame = 0;
  function animateTransit() {
    transitContext.clearRect(0, 0, transitCanvasW, transitCanvasH);
    transitContext.strokeStyle = "#14b8a6";
    transitContext.lineWidth = 1.5;
    transitContext.beginPath();
    transitPoints.forEach(([x, y], i) =>
      i === 0 ? transitContext.moveTo(x, y) : transitContext.lineTo(x, y),
    );
    transitContext.stroke();
    transitContext.fillStyle = "var(--ds-gray-600)";
    transitContext.font = "10px monospace";
    transitContext.fillText("flux", 8, 16);
    transitContext.fillText("time →", transitCanvasW - 52, transitCanvasH - 6);
    transitContext.fillStyle = "#14b8a6";
    transitContext.fillText(
      `−${((planetRadius ** 2 / 100) * 100).toFixed(2)}%`,
      transitCanvasW - 52,
      36,
    );
    const px = (frame / 120) * transitCanvasW;
    const py =
      transitPoints[Math.min(Math.floor(px), transitCanvasW - 1)]?.[1] ?? 20;
    transitContext.beginPath();
    transitContext.arc(px, py - 14, 4, 0, Math.PI * 2);
    transitContext.fillStyle = COLORS[planetType]?.[0] ?? "#888";
    transitContext.fill();
    frame = (frame + 1) % 120;
    requestAnimationFrame(animateTransit);
  }
  animateTransit();

  const orbitCanvas = document.getElementById("orbit-canvas");
  const orbitContext = orbitCanvas.getContext("2d");
  const orbitCanvasW = orbitCanvas.width,
    orbitCanvasH = orbitCanvas.height;
  const orbitCanvasX = orbitCanvasW / 2,
    orbitCanvasY = orbitCanvasH / 2;

  const earthOrbitR = 70;
  const planetOrbitR = Math.min(Math.max(earthOrbitR * 0.6, 40), 110);

  const earthPeriod = 365.25;
  const speedRatio = earthPeriod / (planetPeriod || 365.25);

  document.getElementById("orbit-speed-label").textContent =
    speedRatio > 1
      ? `${speedRatio.toFixed(1)}× faster`
      : `${(1 / speedRatio).toFixed(1)}× slower`;

  document.getElementById("orbit-age-label").textContent = planetPeriod
    ? `${((25 * earthPeriod) / planetPeriod).toFixed(1)} yrs`
    : "—";

  const [planetColor] = COLORS[planetType] ?? COLORS["unknown"];

  let earthAngle = 0;
  let planetAngle = 0;

  function drawOrbit() {
    orbitContext.clearRect(0, 0, orbitCanvasW, orbitCanvasH);

    orbitContext.beginPath();
    orbitContext.arc(orbitCanvasX, orbitCanvasY, 10, 0, Math.PI * 2);
    orbitContext.fillStyle = "#ffd060";
    orbitContext.fill();

    orbitContext.beginPath();
    orbitContext.arc(orbitCanvasX, orbitCanvasY, 14, 0, Math.PI * 2);
    orbitContext.fillStyle = "rgba(255,208,96,0.12)";
    orbitContext.fill();

    orbitContext.beginPath();
    orbitContext.arc(orbitCanvasX, orbitCanvasY, earthOrbitR, 0, Math.PI * 2);
    orbitContext.strokeStyle = "rgba(255,255,255,0.08)";
    orbitContext.lineWidth = 1;
    orbitContext.stroke();

    orbitContext.beginPath();
    orbitContext.arc(orbitCanvasX, orbitCanvasY, planetOrbitR, 0, Math.PI * 2);
    orbitContext.strokeStyle = "rgba(255,255,255,0.08)";
    orbitContext.lineWidth = 1;
    orbitContext.stroke();

    const earthX = orbitCanvasX + earthOrbitR * Math.cos(earthAngle);
    const earthY = orbitCanvasY + earthOrbitR * Math.sin(earthAngle);
    orbitContext.beginPath();
    orbitContext.arc(earthX, earthY, 5, 0, Math.PI * 2);
    orbitContext.fillStyle = "#378ADD";
    orbitContext.fill();

    orbitContext.fillStyle = "rgba(255,255,255,0.3)";
    orbitContext.font = "10px monospace";
    orbitContext.fillText("Earth", earthX + 7, earthY + 4);

    const planetX = orbitCanvasX + planetOrbitR * Math.cos(planetAngle);
    const planetY = orbitCanvasY + planetOrbitR * Math.sin(planetAngle);
    orbitContext.beginPath();
    orbitContext.arc(
      planetX,
      planetY,
      Math.min(Math.max(planetRadius * 2.5, 4), 10),
      0,
      Math.PI * 2,
    );
    orbitContext.fillStyle = planetColor;
    orbitContext.fill();

    orbitContext.fillStyle = "rgba(255,255,255,0.5)";
    orbitContext.font = "10px monospace";
    orbitContext.fillText(planetName.split(" ")[0], planetX + 8, planetY + 4);

    const baseSpeed = (2 * Math.PI) / 600;
    earthAngle += baseSpeed;
    planetAngle += baseSpeed * speedRatio;

    requestAnimationFrame(drawOrbit);
  }
  drawOrbit();

  function spectralToColor(type, temperature) {
    const temp = temperature ?? 5778;

    if (temp > 30000) return ["#9bb0ff", "#b0c0ff"];
    if (temp > 10000) return ["#aabfff", "#c0d0ff"];
    if (temp > 7500) return ["#f8f7ff", "#fffaf0"];
    if (temp > 6000) return ["#fff4e8", "#ffe8d0"];
    if (temp > 5200) return ["#ffdd90", "#ffd060"];
    if (temp > 3700) return ["#ffb347", "#ff8c00"];
    return ["#ff6b35", "#cc4400"];
  }

  function tempToSpectralClass(temperature) {
    if (!temperature) return null;
    if (temperature > 30000) return "O";
    if (temperature > 10000) return "B";
    if (temperature > 7500) return "A";
    if (temperature > 6000) return "F";
    if (temperature > 5200) return "G";
    if (temperature > 3700) return "K";
    return "M";
  }

  const displaySpectral =
    stellarType ?? tempToSpectralClass(stellarTemp) ?? "Unknown";

  const starCanvas = document.getElementById("star-canvas");
  const starContext = starCanvas.getContext("2d");
  const starCanvasW = starCanvas.width,
    starCanvasH = starCanvas.height;
  const starContextX = starCanvasW / 2,
    starContextY = starCanvasH / 2;

  starContext.fillStyle = "rgba(255,255,255,0.5)";
  starContext.font = "11px monospace";
  starContext.textAlign = "center";
  starContext.fillText(displaySpectral, starContextX, starCanvasH - 6);

  const [starColor1, starColor2] = spectralToColor(
    stellarType ?? tempToSpectralClass(stellarTemp),
    stellarTemp,
  );
  const starRadius = Math.min(
    Math.max((stellarRadius ?? 1) * 20, 18),
    starContextX - 8,
  );

  const starGradient = starContext.createRadialGradient(
    starContextX - starRadius * 0.3,
    starContextY - starRadius * 0.3,
    starRadius * 0.05,
    starContextX,
    starContextY,
    starRadius,
  );
  starGradient.addColorStop(0, starColor1);
  starGradient.addColorStop(0.6, starColor2);
  starGradient.addColorStop(1, starColor2 + "44");

  starContext.beginPath();
  starContext.arc(starContextX, starContextY, starRadius, 0, Math.PI * 2);
  starContext.fillStyle = starGradient;
  starContext.fill();

  starContext.beginPath();
  starContext.arc(starContextX, starContextY, starRadius + 6, 0, Math.PI * 2);
  starContext.fillStyle = starColor2 + "18";
  starContext.fill();

  const compare = document.getElementById("size-compare");
  const bodies = [
    { name: "Earth", radius: 1, color: "#378ADD" },
    {
      name: planetName.split(" ")[0],
      radius: Math.max(planetRadius, 0.1),
      color: COLORS[planetType]?.[0] ?? "#888",
    },
    { name: "Neptune", radius: 3.88, color: "#4a8ed4" },
    { name: "Jupiter", radius: 11.2, color: "#E87C1E" },
  ];
  const maxR = Math.max(...bodies.map((body) => body.radius));
  const scale = 44 / maxR;
  bodies.forEach((body) => {
    const px = Math.max(body.radius * scale, 5);
    const div = document.createElement("div");
    div.style.cssText =
      "display:flex;flex-direction:column;align-items:center;gap:8px";
    div.innerHTML = `
      <div style="width:${px * 2}px;height:${px * 2}px;border-radius:50%;background:${body.color};opacity:.85;flex-shrink:0"></div>
      <div style="font-size:10px;color:var(--ds-gray-600);font-family:var(--font-geist-mono);white-space:nowrap">${body.name}</div>
    `;
    compare.appendChild(div);
  });

  const estimatedMass = planetMass ?? Math.pow(planetRadius, 2.06);
  const gravityRatio = Math.max(estimatedMass / planetRadius ** 2, 0.01);
  const slider = document.getElementById("weight-slider");
  const weightOut = document.getElementById("weight-out");
  const resWeight = document.getElementById("res-weight");
  const resGravity = document.getElementById("res-gravity");

  function updateGravity() {
    const w = Number(slider.value);
    weightOut.textContent = `${w} kg`;
    resWeight.textContent = `${(w * gravityRatio).toFixed(1)} kg`;
    resGravity.textContent = `${gravityRatio.toFixed(2)} g`;
  }

  slider.addEventListener("input", updateGravity);
  updateGravity();

  const bmBtn = document.getElementById("bookmark-btn");
  const bmIcon = document.getElementById("bookmark-icon");
  const bmLabel = document.getElementById("bookmark-label");

  function updateBookmarkUI(saved) {
    if (saved) {
      bmBtn.style.borderColor = "var(--ds-green-500)";
      bmBtn.style.color = "var(--ds-green-600)";
      bmIcon.setAttribute("fill", "currentColor");
      bmLabel.textContent = "Saved";
    } else {
      bmBtn.style.borderColor = "";
      bmBtn.style.color = "";
      bmIcon.setAttribute("fill", "none");
      bmLabel.textContent = "Save planet";
    }
  }

  function getBookmarks() {
    try {
      return JSON.parse(localStorage.getItem("exoatlas:bookmarks") ?? "[]");
    } catch {
      return [];
    }
  }

  const planetData = JSON.parse(bmBtn.dataset.planet);

  updateBookmarkUI(getBookmarks().some((b) => b.id === planetData.id));

  bmBtn.addEventListener("click", () => {
    const list = getBookmarks();
    const already = list.some((bm) => bm.id === planetData.id);
    if (already) {
      localStorage.setItem(
        "exoatlas:bookmarks",
        JSON.stringify(list.filter((bm) => bm.id !== planetData.id)),
      );
      updateBookmarkUI(false);
    } else {
      list.unshift({ ...planetData, savedAt: new Date().toISOString() });
      localStorage.setItem("exoatlas:bookmarks", JSON.stringify(list));
      updateBookmarkUI(true);
    }
  });
</script>
