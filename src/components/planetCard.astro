---
interface Props {
  name: string;
  host_star: string;
  distance_ly: number | null;
  radius_earth: number | null;
  orbital_period: number | null;
  eq_temperature: number | null;
  planet_type: string | null;
  discovery_year: number | null;
  esi_score: number | null;
  habitability_pct: number | null;
}

const {
  name,
  host_star,
  distance_ly,
  radius_earth,
  orbital_period,
  eq_temperature,
  planet_type,
  discovery_year,
  esi_score,
  habitability_pct,
} = Astro.props;

const typeConfig: Record<string, { label: string; bg: string; text: string }> =
  {
    rocky: {
      label: "Rocky",
      bg: "bg-amber-100",
      text: "text-amber-500",
    },
    "super-earth": {
      label: "Super-earth",
      bg: "bg-teal-200",
      text: "text-teal-800",
    },
    "sub-neptune": {
      label: "Sub-neptune",
      bg: "bg-blue-200",
      text: "text-blue-600",
    },
    "neptune-like": {
      label: "Neptune-like",
      bg: "bg-blue-200",
      text: "text-blue-800",
    },
    "ocean-world": {
      label: "Ocean world",
      bg: "bg-blue-200",
      text: "text-blue-800",
    },
    "hot-jupiter": {
      label: "Hot Jupiter",
      bg: "bg-amber-200",
      text: "text-amber-800",
    },
    "gas-giant": {
      label: "Gas giant",
      bg: "bg-purple-100",
      text: "text-purple-900",
    },
    unknown: { label: "Unknown", bg: "bg-gray-200", text: "text-gray-700" },
  };

const type = typeConfig[planet_type ?? "unknown"] ?? typeConfig["unknown"];

const habColor =
  (habitability_pct ?? 0) >= 70
    ? "bg-green-600"
    : (habitability_pct ?? 0) >= 40
      ? "bg-amber-600"
      : "bg-red-600";

const slug = name.toLowerCase().replace(/\s+/g, "-");

const fmt = (v: number | null, decimals = 2) =>
  v != null ? v.toFixed(decimals) : "—";

const period =
  orbital_period == null
    ? "—"
    : orbital_period < 1
      ? `${(orbital_period * 24).toFixed(1)}h`
      : orbital_period > 1000
        ? `${(orbital_period / 365.25).toFixed(1)}yr`
        : `${orbital_period.toFixed(1)}d`;
---

<a
  href={`/planet/${slug}`}
  class="group block bg-background-200 border border-white/10 rounded-xl overflow-hidden hover:border-white/20 transition-colors duration-150"
>
  <div
    class="h-28 bg-background-100 flex items-center justify-center border-b border-gray-200"
  >
    <canvas
      class="planet-canvas"
      data-type={planet_type}
      data-radius={radius_earth}
      data-temp={eq_temperature}
      width="80"
      height="80"></canvas>
  </div>

  <div class="p-3">
    <div class="flex items-start justify-between gap-2 mb-1">
      <div>
        <div class="text-heading-14 font-medium text-primary leading-tight">
          {name}
        </div>
        <div class="text-xs text-secondary font-mono mt-0.5">{host_star}</div>
      </div>
      <span
        class={`shrink-0 text-xs font-medium px-2 py-0.5 rounded-full ${type.bg} ${type.text}`}
      >
        {type.label}
      </span>
    </div>

    <div class="flex items-center gap-2 mt-3 mb-1">
      <div class="flex-1 h-1 bg-gray-300 rounded-full overflow-hidden">
        <div
          style={`width: ${habitability_pct ?? 0}%;`}
          class={`h-full rounded-full ${habColor}`}
        >
        </div>
      </div>
      <span class="font-mono text-xs text-gray-600 tabular-nums w-8 text-right">
        {habitability_pct ?? 0}%
      </span>
    </div>

    <div
      class="grid grid-cols-2 gap-x-3 gap-y-1.5 mt-3 pt-3 border-t border-gray-200"
    >
      <div>
        <div class="text-gray-500 text-[10px] upercase tracking-wider">
          Radius
        </div>
        <div class="font-mono text-xs text-gray-900 mt-0.5">
          {fmt(radius_earth)} R⊕
        </div>
      </div>
      <div>
        <div class="text-gray-500 text-[10px] upercase tracking-wider">
          Period
        </div>
        <div class="font-mono text-xs text-gray-900 mt-0.5">{period}</div>
      </div>
      <div>
        <div class="text-gray-500 text-[10px] upercase tracking-wider">
          Temp
        </div>
        <div class="font-mono text-xs text-gray-900 mt-0.5">
          {fmt(eq_temperature, 0)} K
        </div>
      </div>
      <div>
        <div class="text-gray-500 text-[10px] upercase tracking-wider">
          Found
        </div>
        <div class="font-mono text-xs text-gray-900 mt-0.5">
          {discovery_year ?? "—"}
        </div>
      </div>
    </div>
  </div>

  <script>
    const COLORS: Record<string, string[]> = {
      rocky: ["#8a7040", "#6a5030"],
      "super-earth": ["#3a9e75", "#1a7e55"],
      "sub-neptune": ["#4a8ed4", "#2a6eb4"],
      "neptune-like": ["#3a7ed4", "#1a5eb4"],
      "ocean-world": ["#3a7ed4", "#1a5eb4"],
      "hot-jupiter": ["#E87C1E", "#c85c0e"],
      "gas-giant": ["#8a5bc4", "#6a3ba4"],
      unknown: ["#505050", "#303030"],
    };

    document
      .querySelectorAll<HTMLCanvasElement>(".planet-canvas")
      .forEach((canvas) => {
        const type = canvas.dataset.type ?? "unknown";
        const radius = parseFloat(canvas.dataset.radius ?? "1");
        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        const [c1, c2] = COLORS[type] ?? COLORS["unknown"];
        const size = canvas.width;
        const cx = size / 2;
        const cy = size / 2;
        const r = Math.min(Math.max(radius * 10, 8), size * 0.44);

        const grad = ctx.createRadialGradient(
          cx - r * 0.3,
          cy - r * 0.3,
          r * 0.1,
          cx,
          cy,
          r,
        );
        grad.addColorStop(0, c1);
        grad.addColorStop(1, c2);

        ctx.beginPath();
        ctx.arc(cx, cy, r, 0, Math.PI * 2);
        ctx.fillStyle = grad;
        ctx.fill();

        ctx.beginPath();
        ctx.arc(cx - r * 0.25, cy - r * 0.25, r * 0.35, 0, Math.PI * 2);
        ctx.fillStyle = "rgba(255,255,255,0.07)";
        ctx.fill();
      });
  </script>
</a>
