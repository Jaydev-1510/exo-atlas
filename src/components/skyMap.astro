---
interface Props {
  ra: number | null;
  dec: number | null;
  name: string;
}

const { ra, dec, name } = Astro.props;
---

<div class="bg-background-200 border border-gray-300 rounded-xl p-5 mb-6">
  <div class="font-mono text-xs text-gray-600 uppercase tracking-widest mb-4">
    Sky map — where to find it
  </div>
  {
    ra != null && dec != null ? (
      <div class="relative">
        <canvas
          id="sky-canvas"
          width="600"
          height="220"
          style="width:100%;height:220px;border-radius:8px;border:1px solid #1f1f1f"
        />
        <div
          id="sky-tooltip"
          style="display:none;position:absolute;background:var(--ds-background-100);border:0.5px solid var(--ds-gray-400);border-radius:6px;padding:6px 10px;font-size:11px;font-family:var(--font-geist-mono);color:var(--secondary);pointer-events:none"
        />
      </div>
    ) : (
      <div class="text-sm text-gray-600 py-6 text-center">
        No sky coordinates available for this planet
      </div>
    )
  }
</div>

<script is:inline define:vars={{ ra, dec, starName: name }}>
  if (ra != null && dec != null) {
    const canvas = document.getElementById("sky-canvas");
    canvas.width = canvas.offsetWidth || 600;
    const W = canvas.width,
      H = canvas.height;
    const ctx = canvas.getContext("2d");

    ctx.fillStyle = "#000000";
    ctx.fillRect(0, 0, W, H);

    ctx.strokeStyle = "rgba(255,255,255,0.04)";
    ctx.lineWidth = 0.5;
    for (let r = 0; r <= 360; r += 30) {
      const x = (r / 360) * W;
      ctx.beginPath();
      ctx.moveTo(x, 0);
      ctx.lineTo(x, H);
      ctx.stroke();
    }

    for (let d = -90; d <= 90; d += 30) {
      const y = ((90 - d) / 180) * H;
      ctx.beginPath();
      ctx.moveTo(0, y);
      ctx.lineTo(W, y);
      ctx.stroke();
    }

    ctx.fillStyle = "rgba(255,255,255,0.2)";
    ctx.font = "9px monospace";
    for (let r = 0; r <= 360; r += 60) {
      ctx.fillText(`${r}°`, (r / 360) * W + 2, H - 4);
    }
    for (let d = -60; d <= 90; d += 30) {
      ctx.fillText(`${d > 0 ? "+" : ""}${d}°`, 2, ((90 - d) / 180) * H - 2);
    }

    const seed = 42;
    function rand(n) {
      return (((Math.sin(n * seed) * 43758.5453) % 1) + 1) % 1;
    }
    for (let i = 0; i < 400; i++) {
      const sx = rand(i * 3) * W;
      const sy = rand(i * 3 + 1) * H;
      const size = rand(i * 3 + 2) * 1.2;
      ctx.beginPath();
      ctx.arc(sx, sy, size, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255,255,255,${0.1 + rand(i) * 0.5})`;
      ctx.fill();
    }

    const neighbors = [
      { ra: ra + 8, dec: dec + 5 },
      { ra: ra - 12, dec: dec - 8 },
      { ra: ra + 20, dec: dec + 2 },
      { ra: ra - 5, dec: dec + 14 },
      { ra: ra + 15, dec: dec - 10 },
    ];
    neighbors.forEach((n) => {
      const nx = ((((n.ra % 360) + 360) % 360) / 360) * W;
      const ny = ((90 - Math.max(-90, Math.min(90, n.dec))) / 180) * H;
      ctx.beginPath();
      ctx.arc(nx, ny, 1.5, 0, Math.PI * 2);
      ctx.fillStyle = "rgba(255,255,255,0.4)";
      ctx.fill();

      const hx = ((((ra % 360) + 360) % 360) / 360) * W;
      const hy = ((90 - dec) / 180) * H;
      ctx.beginPath();
      ctx.moveTo(nx, ny);
      ctx.lineTo(hx, hy);
      ctx.strokeStyle = "rgba(255,255,255,0.04)";
      ctx.lineWidth = 0.5;
      ctx.stroke();
    });

    const hx = ((((ra % 360) + 360) % 360) / 360) * W;
    const hy = ((90 - dec) / 180) * H;

    [16, 10, 6].forEach((r, i) => {
      ctx.beginPath();
      ctx.arc(hx, hy, r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255,208,96,${[0.04, 0.08, 0.15][i]})`;
      ctx.fill();
    });

    ctx.beginPath();
    ctx.arc(hx, hy, 3.5, 0, Math.PI * 2);
    ctx.fillStyle = "#ffd060";
    ctx.fill();

    ctx.fillStyle = "rgba(255,208,96,0.9)";
    ctx.font = "11px monospace";
    ctx.fillText(starName, hx + 10, hy - 8);

    ctx.fillStyle = "rgba(255,255,255,0.3)";
    ctx.font = "10px monospace";
    ctx.textAlign = "right";
    ctx.fillText(`RA ${ra.toFixed(4)}°  Dec ${dec.toFixed(4)}°`, W - 8, H - 6);

    ctx.strokeStyle = "rgba(255,208,96,0.25)";
    ctx.lineWidth = 0.5;
    ctx.setLineDash([4, 4]);
    ctx.beginPath();
    ctx.moveTo(hx, 0);
    ctx.lineTo(hx, H);
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(0, hy);
    ctx.lineTo(W, hy);
    ctx.stroke();
    ctx.setLineDash([]);
  }
</script>
