---
const links = [
  { href: "/", label: "Home" },
  { href: "/atlas", label: "Atlas" },
  { href: "/timeline", label: "Timeline" },
  { href: "/systems", label: "Systems" },
  { href: "/collections", label: "Saved" },
];
---

<header
  class="fixed top-0 w-screen z-50 flex justify-center pt-6 px-4 bg-linear-to-b from-black to-transparent"
>
  <nav
    class="flex h-14 w-full max-w-5xl px-3 items-center justify-between rounded-2xl border border-white/10 bg-black/40 backdrop-blur-xl transition-all duration-500 hover:border-white/20 hover:bg-black/60 shadow-[0_20px_50px_rgba(0,0,0,0.3)]"
    aria-label="Primary navigation"
  >
    <a
      href="/"
      title="Home - exoAtlas"
      class="group flex items-center gap-3"
      aria-label="exoAtlas homepage"
    >
      <img
        src="/favicon.svg"
        alt=""
        class="object-contain h-8 w-8 transition-transform duration-500 group-hover:scale-110"
      />
      <span
        class="hidden md:block text-xs font-bold uppercase tracking-[0.3em] text-white/90"
      >
        exoAtlas
      </span>
    </a>

    <ul class="flex items-center gap-6">
      {
        links.map((l) => {
          const isActive = Astro.url.pathname === l.href;
          return (
            <li class="relative group">
              <a
                href={l.href}
                aria-current={isActive ? "page" : undefined}
                class={`text-[11px] font-bold uppercase tracking-widest transition-colors duration-300 ${isActive ? "text-primary" : "text-secondary group-hover:text-primary"}`}
              >
                {l.label}
              </a>
              <span
                class={`absolute left-0 bottom-0 h-px bg-gray-500 transition-all duration-300 ${isActive ? "w-full" : "w-0 group-hover:w-full"}`}
              />
            </li>
          );
        })
      }
    </ul>

    <span
      class="hidden md:inline-block text-[10px] font-mono text-secondary/80 bg-secondary/10 px-2 py-1 rounded-4xl border border-gray-500/20"
    >
      LIVE_DATA
    </span>
  </nav>
</header>
